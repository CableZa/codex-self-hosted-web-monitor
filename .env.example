# Copy this file to .env before first startup if you want to override defaults.
# Docker Compose reads .env automatically from the repo root.

# Local day boundaries, weekly windows, and summary times.
TIMEZONE=UTC

# Optional host path to Codex data.
# Leave unset on macOS/Linux unless your Codex home is not ~/.codex.
# Windows examples:
# CODEX_HOST_HOME=C:/Users/YourName/.codex
# CODEX_HOST_HOME=${USERPROFILE}/.codex
# WSL reading native Windows Codex data:
# CODEX_HOST_HOME=/mnt/c/Users/YourName/.codex
# CODEX_HOST_HOME=

# Pricing settings.
# Credits are the default and do not require live FX, ZAR conversion, or a custom CA bundle.
PRICING_MODE=credits
FX_LIVE_ENABLED=false
USD_ZAR_FALLBACK_RATE=18.50

# Optional webhook endpoint for account alerts and summaries.
# Leave empty to disable outbound webhooks.
WEBHOOK_URL=
WEBHOOK_UI_ENABLED=false
DASHBOARD_URL=http://127.0.0.1:18787

# Dashboard behavior.
# Use "full" for all dashboard features.
# Use "focused" to focus configured work accounts.
DASHBOARD_MODE=full
UI_THEME=catppuccin

# Optional automatic weekly account limits for matching email suffixes.
# Leave suffixes empty to disable automatic limit creation.
# Example:
# AUTO_ACCOUNT_LIMIT_EMAIL_SUFFIXES=@example.com,@team.example
AUTO_ACCOUNT_LIMIT_EMAIL_SUFFIXES=
AUTO_ACCOUNT_LIMIT_CAP_CREDITS=400
AUTO_ACCOUNT_LIMIT_RESET_WEEKDAY=4
AUTO_ACCOUNT_LIMIT_RESET_TIME=00:00
AUTO_ACCOUNT_LIMIT_TIMEZONE=UTC
AUTO_ACCOUNT_LIMIT_THRESHOLDS=0.7,0.85,0.95,1.0

# Cache and scanner settings.
VALKEY_URL=redis://valkey:6379/0
CACHE_KEY_PREFIX=codex-monitor
# Keep this at disabled for multi-worker Docker runs.
# Use always only for local single-machine troubleshooting.
CACHE_MEMORY_FALLBACK_MODE=single-worker
# Docker starts this many Uvicorn API workers through scripts/run-api.
# Keep this at 1 unless Valkey is healthy and the scanner runs separately.
MONITOR_API_WORKERS=1
TODAY_CACHE_TTL_SECONDS=90
HISTORIC_CACHE_TTL_SECONDS=604800
DEFAULT_DAYS_BACK=30
MAX_DATE_RANGE_DAYS=366
MAX_ACCOUNT_FILTERS=50
MAX_ALERT_LIMIT=200
FX_FALLBACK_RETRY_SECONDS=3600
SCANNER_ENABLED=true

# Optional outbound TLS trust.
# Leave blank for normal credits-only local monitoring.
# Set this only if live FX or HTTPS webhooks fail behind company TLS inspection.
# Example:
# CUSTOM_CA_BUNDLE=/certs/macos-ca-bundle.pem
CUSTOM_CA_BUNDLE=

# Logging and diagnostics.
LOG_LEVEL=INFO
DEBUG_TIMING_ENABLED=true

# Host update status bridge. Docker reads the host-written status file from /runtime.
# Windows local runs use runtime/update-status.json by default.
# UPDATE_STATUS_PATH=/runtime/update-status.json
