#!/usr/bin/env sh
set -eu

export COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-codex-self-hosted-web-monitor-test}"

cleanup() {
  docker-compose -f docker-compose.test.yml down --remove-orphans >/dev/null 2>&1 || true
}

trap cleanup EXIT

docker-compose -f docker-compose.test.yml build backend-test frontend-test
docker-compose -f docker-compose.test.yml run --rm backend-test
